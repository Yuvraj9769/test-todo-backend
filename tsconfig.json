{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*"],
  "files": ["src/types/express.d.ts"],   // ← force include
  "ts-node": {
    "files": true    // ← tells ts-node to respect "files" above
  }
}